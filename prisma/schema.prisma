generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  UPLOADING
  RECEIVED
  IN_PRODUCTION
  COMPLETED
  FAILED
}

enum UploadStatus {
  PENDING
  UPLOADING
  UPLOADED
  FAILED
}

model User {
  id           String    @id @default(cuid())
  role         UserRole  @default(USER)
  firstName    String
  lastName     String
  companyName  String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  orders       Order[]
  layouts      Layout[]
  artworkAssets ArtworkAsset[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  status        OrderStatus @default(UPLOADING)
  fileCount     Int
  subtotalPence Int
  vatPence      Int
  totalPence    Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  files         OrderFile[]

  @@index([userId, createdAt])
  @@index([status])
}

model OrderFile {
  id                 String       @id @default(cuid())
  orderId            String
  originalName       String
  mimeType           String
  bytes              Int
  quantity           Int          @default(1)
  uploadStatus       UploadStatus @default(PENDING)
  cloudinaryPublicId String?
  cloudinaryUrl      String?
  errorMessage       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  order              Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([uploadStatus])
}

enum LayoutBackgroundMode {
  LIGHT
  DARK
}

model Layout {
  id               String               @id @default(cuid())
  userId           String
  name             String
  backgroundMode   LayoutBackgroundMode @default(LIGHT)
  canvasWidthMm    Int                  @default(560)
  canvasHeightMm   Int                  @default(1000)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            LayoutItem[]

  @@index([userId, createdAt])
}

model ArtworkAsset {
  id                 String       @id @default(cuid())
  userId             String
  originalName       String
  mimeType           String
  bytes              Int
  widthPx            Int?
  heightPx           Int?
  dpiX               Int?
  dpiY               Int?
  aspectRatio        Float?
  uploadStatus       UploadStatus @default(PENDING)
  cloudinaryPublicId String?
  cloudinaryUrl      String?
  errorMessage       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  layoutItems        LayoutItem[]

  @@index([userId, createdAt])
  @@index([uploadStatus])
}

model LayoutItem {
  id             String       @id @default(cuid())
  layoutId       String
  artworkAssetId String
  xMm            Float
  yMm            Float
  widthMm        Float
  heightMm       Float
  rotationDeg    Float        @default(0)
  quantity       Int          @default(1)
  zIndex         Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  layout         Layout       @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  artworkAsset   ArtworkAsset @relation(fields: [artworkAssetId], references: [id], onDelete: Cascade)

  @@index([layoutId, zIndex])
  @@index([artworkAssetId])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  bucketKey   String
  windowStart DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([bucketKey, windowStart])
  @@index([updatedAt])
}
